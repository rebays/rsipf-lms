DATABASE_URI=postgresql://postgres:postgres@localhost:5432/rsipf_lms
PAYLOAD_SECRET=replace-with-long-random-string
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@rsipf.local
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# S3-compatible object storage (MinIO for local dev — see compose.local.yml)
