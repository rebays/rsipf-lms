{
  "name": "rsipf-lms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/patch-next-env.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx --env-file=.env src/seed.ts",
    "payload": "payload",
    "db:up": "docker compose -f compose.local.yml up -d postgres",
